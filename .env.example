# Admin Auth
ADMIN_PASSWORD=your-secure-password

# LLM Providers
TEXT_PROVIDER=gemini  # "gemini" (default) or "huggingface"
GOOGLE_AI_API_KEY=    # required if using gemini
GOOGLE_CLOUD_PROJECT_ID=  # project id owning GOOGLE_AI_API_KEY (e.g. gen-lang-client-XXXX), used for Cloud Console usage links
HUGGINGFACE_API_KEY=  # required if using huggingface

# Image Generation
POLLINATIONS_API_KEY= # pollinations.ai works without auth but rate limited

# Instagram / Meta (from developers.facebook.com)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# Cron (protects /api/cron/* endpoints)
CRON_SECRET=your-cron-secret
